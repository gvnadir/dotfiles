    },
    "[Kanagawa]": {
      // "editor.background": "#1e1e1e"
    },
    "[Eclipse Dark]": {
      "statusBar.background": "#252526",
      "statusBarItem.remoteBackground": "#252526"
    },
    "[One Dark Pro Vivid]": {},
    "[Default Dark+]": {
      "statusBar.background": "#2c2c2c"
    },
    "[Base16 Dark Default]": {
      "statusBar.background": "#181818",
      "statusBarItem.remoteBackground": "#181818"
    },
    "[Railgun]": {
      "statusBarItem.remoteBackground": "#222222"
    },
    "[Gruvbox Dark (Hard)]": {
      "statusBar.background": "#292828",
      "statusBarItem.remoteBackground": "#292828"
    },
    "[Gruvbox Dark (Medium)]": {
      "statusBar.background": "#292828",
      "statusBarItem.remoteBackground": "#292828"
