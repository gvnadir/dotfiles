99d-4e54-b29e-406e365b3765","publisherId":"99c51d59-fc09-4f31-b119-7700b8c217c0","publisherDisplayName":"Jabor047","targetPlatform":"undefined","updated":false,"isPreReleaseVersion":false,"hasPreReleaseVersion":false,"installedTimestamp":1709927485227,"pinned":false},"isValid":true,"validations":[]},{"type":1,"identifier":{"id":"andreistebakov.sailpoint-iiq-dev-accelerator","uuid":"046cc59e-9347-48b0-a784-b854b715b990"},"manifest":{"name":"sailpoint-iiq-dev-accelerator","displayName":"Sailpoint IIQ Development Accelerator","description":"Provides commands to facilitate/accelerate coding/interacting with remote Sailpoint IIQ server","icon":"images/icon.png","version":"10.0.58","engines":{"vscode":"^1.60.0"},"keywords":["sailpoint","iiq","beanshell","remote","development","deployment","automation"],"author":{"name":"Andrei Stebakov","email":"lispercat@gmail.com"},"repository":{"type":"git","url":"https://github.com/lispercat/sailpoint-iiq-dev-accelerator"},"license":"MIT","publisher":"AndreiStebakov","contributors":[{"name":"Andrei Stebakov","email":"lispercat@gmail.com"},{"name":"Anthony Conrad","email":"parithon@outlook.com"},{"name":"Claes Johansson","email":"claexon@gmail.com"},{"name":"Yannick Béot"}],"categories":["Other"],"extensionDependencies":["vscode.git"],"activationEvents":["workspaceContains:**/config/**/*.xml","onLanguage:xml"],"main":"./client/out/extension.js","contributes":{"configuration":{"languages":[{"id":"beanshell","aliases":["beanshell","BEANSHELL"],"extensions":[".xml"],"configuration":"./antlr.configuration.json"}],"title":"Sailpoint IIQ Development Accelerator","properties":{"iiq-dev-accelerator.environment":{"type":"string","description":"iiq environment (dev, uat, prod, etc)","default":"","scope":"application"},"iiq-dev-accelerator.iiq_url":{"type":"string","description":"url for your iiq site","default":"","scope":"application"},"iiq-dev-accelerator.username":{"type":"string","description":"username","default":"","scope":"application"},"iiq-dev-accelerator.password":{"type":"string","description":"password","default":"","scope":"application"},"iiq-dev-accelerator.showDeleteProgress":{"type":"boolean","description":"When set to true, you will see a progress bar when deleting multiple objects. It makes the process slower, but more tangible","default":true,"scope":"application"},"iiq-dev-accelerator.deployCustomBuildQuietly":{"type":"boolean","description":"When set to true, you will not be asked during custom build to confirm the list of files to import","default":false,"scope":"application"},"iiq-dev-accelerator.iiq_lib_path":{"type":"string","description":"Path to your IIQ libraries, usually resides under WEB-INF/lib path","default":null,"scope":"application"},"iiq-dev-accelerator.maxNumberOfProblems":{"type":"number","description":"Controls the maximum number of problems produced by the server.","default":100,"scope":"resource"},"iiq-dev-accelerator.enableLSP":{"type":"boolean","description":"When set to true, the language server protocol will be enabled","default":false,"scope":"application"},"iiq-dev-accelerator.disableTLSValidation":{"type":"boolean","description":"This option is quite insecure since it sets process.env.NODE_TLS_REJECT_UNAUTHORIZED = 0 which allows you to connect to your server ignoring certificate issues","default":false,"scope":"application"},"iiq-dev-accelerator.mode":{"type":"string","description":"Change mode between SSB or devsecops","enum":["SSB","devsecops"],"default":"SSB","scope":"application"},"iiq-dev-accelerator.sort":{"type":"string","description":"Sorting option when listing objects","enum":["name","modified"],"enumDescriptions":["Sort by name","Sort by modified date"],"enumItemLabels":["Name","Last Modified"],"default":"name"},"iiq-dev-accelerator.useTokenization":{"type":"string","enum":["Yes","No","Ask"],"enumDescriptions":["Tokenization will be applied each time","Tokenization will never be used","The extension will asked each time"],"description":"Define whether tokenization is used or not","default":"Ask","maxLength":0},"iiq-dev-accelerator.defaultExportObjectsPattern":{"type":"string","description":"Define the pattern for the folder to export objects","scope":"application"},"iiq-dev-accelerator.defaultExportObjectPattern":{"type":"string","description":"Define the pattern for the folder to get an object","scope":"application"},"iiq-dev-accelerator.keyStorePassword":{"type":"string","description":"Password for the java store on the tomcat (server) side","default":"changeit","scope":"application"},"iiq-dev-accelerator.restartTomcatOnNewCertImport":{"type":"boolean","description":"Set to true if you want tomcat to be restarted automatically, otherwise you'll need to restart it manually for new certificates to take effects","default":false,"scope":"application"}}},"commands":[{"command":"iiq-dev-accelerator.importFileRoot","title":"iiq: Import Current File"},{"command":"iiq-dev-accelerator.runTask","title":"iiq: Run Task"},{"command":"iiq-dev-accelerator.runTaskWithAttr","title":"iiq: Run Task With Parameters"},{"command":"iiq-dev-accelerator.runRule","title":"iiq: Run Rule"},{"command":"iiq-dev-accelerator.evalBS","title":"iiq: Evaluate BeanShell Script"},{"command":"iiq-dev-accelerator.getLog","title":"iiq: Get Logging Config"},{"command":"iiq-dev-accelerator.reloadLog","title":"iiq: Reload Logging Config"},{"command":"iiq-dev-accelerator.getObject","title":"iiq: Get Object"},{"command":"iiq-dev-accelerator.deleteObject","title":"iiq: Delete Objects"},{"command":"iiq-dev-accelerator.deleteCurrentObject","title":"iiq: Delete Current Object"},{"command":"iiq-dev-accelerator.switchEnv","title":"iiq: Switch Environment"},{"command":"iiq-dev-accelerator.runContext","title":"iiq: Context-based Execution"},{"command":"iiq-dev-accelerator.deployChange","title":"iiq: Deploy Uncommitted Change"},{"command":"iiq-dev-accelerator.deployCustomBuild","title":"iiq: Deploy Custom Build"},{"command":"iiq-dev-accelerator.compareLocalWith