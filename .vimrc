" Set <Space> as the leader key
let mapleader = "\<Space>"

" Map <leader>cy to "+y in normal mode
nnoremap <leader>y "+y

" Map <leader>cp to "+p in normal mode
nnoremap <leader>p "+p

" Map <leader>cy to "+y in visual mode
vnoremap <leader>y "+y

" Map <leader>cp to "+p in visual mode
vnoremap <leader>p "+p

set relativenumber
set guifont=Fixedsys\ Excelsior\ 3.01-L2\ Mono\ Regular\ 16
set belloff=all
set tabstop=2

